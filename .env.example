# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internship_os_dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication (Better Auth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-min-32-chars-change-in-production

# Email (optional for local dev - password reset / alerts are skipped when unset)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Job OS <onboarding@resend.dev>

# OpenAI (resume parsing, requirement extraction, evidence matching)
OPENAI_API_KEY=sk-your-openai-api-key

# Job polling cron auth
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Cost guardrails (optional - defaults shown)
# MAX_EVALUATIONS_PER_RUN=25    # LLM validation calls per matching run
# MAX_EXTRACTIONS_PER_POLL=25   # requirement extractions per job poll
