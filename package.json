    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "mammoth": "^1.11.0",
    "next": "^16.1.6",
    "nuqs": "^2.8.9",
    "openai": "^6.27.0",
    "pdf2json": "^4.0.2",
    "pg": "^8.20.0",
    "pg-boss": "^12.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
